FROM python:3.12-slim

# Install system dependencies
RUN apt-get update && apt-get install -y \
    git \
    curl \
    bash \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy crewai-specific code
COPY services/agent-worker/internal/agents/crewai /app/internal/agents/crewai
COPY services/agent-worker/internal/tools /app/internal/tools
COPY services/agent-worker/internal/workspace /app/internal/workspace
COPY services/agent-worker/internal/messaging /app/internal/messaging

# Install only crewai-specific dependencies (minimal - no langchain/langgraph)
RUN pip install --no-cache-dir \
    crewai>=1.3.0 \
    crewai-tools>=1.14.7 \
    pexpect>=4.9.0 \
    nats-py>=2.15.0 \
    pydantic>=2.13.4

# Copy common scripts
COPY services/agent-worker/scripts/container-start.sh /app/container-start.sh
RUN chmod +x /app/container-start.sh
COPY services/agent-worker/scripts/clone-repo.sh /app/scripts/clone-repo.sh
RUN chmod +x /app/scripts/clone-repo.sh

# Copy agents.md for code quality guidelines
COPY agents.md /app/agents.md

# Set worker-specific environment variables
ENV WORKSPACE_PATH=/workspace
ENV PYTHONPATH=/app/internal/agents/crewai/src
ENV PYTHON_MODULE=agent_worker.main
