FROM python:3.12-slim

# Install system dependencies
RUN apt-get update && apt-get install -y \
    git \
    docker-cli \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /app

# NOTE: build context is the repository root (see Makefile) so that the shared
# agent_core package can be copied into the image.

# Shared core package (single source of truth for config/db/models/messaging),
# importable via PYTHONPATH=/app.
COPY shared/agent-core/agent_core /app/agent_core

# Copy agent worker code
COPY services/agent-worker/ /app/

# Install Python dependencies from pyproject.toml
RUN pip install --no-cache-dir -e .

# Create workspace directory
RUN mkdir -p /workspace

# Copy startup script
COPY services/agent-worker/scripts/container-start.sh /app/container-start.sh
RUN chmod +x /app/container-start.sh

# Set environment variables
ENV PYTHONPATH=/app
ENV WORKSPACE_PATH=/workspace

# Run startup script
CMD ["/app/container-start.sh"]
