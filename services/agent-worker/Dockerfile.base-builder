FROM python:3.12-slim

# Install system dependencies for git and Docker CLI
RUN apt-get update && apt-get install -y \
    git \
    docker-cli \
    curl \
    bash \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /app

# Copy common internal code (shared by all workers)
COPY services/agent-worker/internal /app/internal
COPY services/agent-worker/pyproject.toml /app/pyproject.toml

# Install common dependencies (shared by langchain-based workers)
ENV PIP_DEFAULT_TIMEOUT=300
RUN pip install --no-cache-dir \
    langchain>=1.3.11 \
    langchain-openai>=0.3.5 \
    langchain-anthropic>=0.4.8 \
    langchain-ollama>=1.1.0 \
    langgraph>=1.2.9 \
    pydantic>=2.13.4 \
    pydantic-settings>=2.14.2 \
    httpx>=0.28.1 \
    PyYAML>=6.0.3 \
    jsonschema>=4.26.0 \
    docker>=7.2.0 \
    nats-py>=2.15.0 \
    aiohttp>=3.14.1

# Copy common scripts
COPY services/agent-worker/scripts/container-start.sh /app/container-start.sh
RUN chmod +x /app/container-start.sh
COPY services/agent-worker/scripts/clone-repo.sh /app/scripts/clone-repo.sh
RUN chmod +x /app/scripts/clone-repo.sh

# Copy agents.md for code quality guidelines
COPY agents.md /app/agents.md

# Set common environment variables
ENV WORKSPACE_PATH=/workspace
ENV PYTHONPATH=/app
