FROM agentic-agents-platform-agent-worker-base-builder:latest

# Copy specialist-specific code
COPY services/agent-worker/internal/agents/specialist /app/internal/agents/specialist
COPY services/agent-worker/internal/workflow /app/internal/workflow
COPY services/agent-worker/internal/tools /app/internal/tools
COPY services/agent-worker/internal/skills /app/internal/skills
COPY services/agent-worker/internal/workspace /app/internal/workspace

# Install specialist-specific dependencies
RUN pip install --no-cache-dir \
    langgraph-checkpoint-postgres>=3.0.5 \
    psycopg-binary>=3.2.6 \
    sqlalchemy>=2.0.51 \
    asyncpg>=0.31.0 \
    alembic>=1.18.5 \
    fastapi>=0.139.0 \
    sse-starlette>=3.4.5 \
    langsmith>=0.10.2 \
    playwright>=1.61.0

# Install Playwright browser for web automation tasks
RUN playwright install chromium

# Set worker-specific environment variables
ENV PYTHON_MODULE=internal.agents.specialist.main
